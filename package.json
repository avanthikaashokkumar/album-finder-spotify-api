{
  "name": "album-finder-spotify-api",
  "version": "1.0.0",
  "description": "A beginner-friendly web app that searches Spotify artists and displays their albums.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "nodemon server/server.js",
    "start": "node server/server.js",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "vite": "^6.0.7"
  }
}
